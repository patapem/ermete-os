{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor",
    "github>whitesource/merge-confidence:beta"
  ],
  "rebaseWhen": "auto",
  "minimumReleaseAge": "7 days",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+ARG [A-Z_]+_VER=\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+ARG [A-Z_]+_COMMIT=\"(?<currentDigest>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)Justfile$",
        "\\.toml$",
        "\\.yml$",
        "\\.ks$"
      ],
      "matchStrings": [
        "(?<depName>quay\\.io/centos-bootc/bootc-image-builder)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "(?<depName>ghcr\\.io/patapem/ermete-os)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "(?<depName>ghcr\\.io/patapem/ermete-base-nvidia)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["^ghcr\\.io/patapem/"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "matchManagers": ["dockerfile", "custom.regex"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
