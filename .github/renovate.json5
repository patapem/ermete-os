{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor",
    "github>whitesource/merge-confidence:beta"
  ],
  "rebaseWhen": "auto",
  "packageRules":,
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "extends":
    },
    {
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes":,
      "automerge": true
    }
  ]
}
