#!/bin/bash
# ==============================================================================
# ERMETE OS: SUPREME OMNI-VISION DIAGNOSTIC TOOL (X-RAY) v5.0 (EXTREME)
# La vetta teorica della diagnostica. Non lascia scampo a nessun bug.
# Analizza ogni atomo del sistema e fornisce l'estratto log in caso di errore.
# ==============================================================================

set -eo pipefail
LOG_FILE="/var/log/ermete-xray-$(date +%Y%m%d_%H%M%S).log"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

exec > >(tee -a "$LOG_FILE") 2>&1

# Funzione per analizzare il fallimento di un servizio
analyze_service() {
    local service=$1
    local is_user=$2
    local syscmd="systemctl is-active --quiet $service"
    [ "$is_user" == "user" ] && syscmd="su -s /bin/bash - $ACTIVE_USER -c \"XDG_RUNTIME_DIR=/run/user/$ACTIVE_UID systemctl --user is-active --quiet $service\""
    
    if eval "$syscmd"; then
        echo -e "${GREEN}✅ $service: Attivo e funzionante.${NC}"
    else
        if [ "$service" == "fwupd.service" ] && ! systemctl is-failed --quiet fwupd.service; then
            echo -e "${GREEN}✅ $service: Inattivo (Normale per Type=idle/dbus).${NC}"
            return
        fi
        echo -e "${RED}❌ ERRORE: $service è fallito o inattivo!${NC}"
        echo -e "${YELLOW}>> Estrazione Root Cause (ultimi log):${NC}"
        local journalcmd="journalctl -u $service -b 0 --no-pager -n 10"
        [ "$is_user" == "user" ] && journalcmd="su -s /bin/bash - $ACTIVE_USER -c \"XDG_RUNTIME_DIR=/run/user/$ACTIVE_UID journalctl --user -u $service -b 0 --no-pager -n 10\""
        eval "$journalcmd" | while read -r line; do echo -e "${RED}   $line${NC}"; done
    fi
}

echo -e "${MAGENTA}========================================================================${NC}"
echo -e "${MAGENTA}   🦅 ERMETE OS - SUPREME OMNI-VISION X-RAY v5.0 (EXTREME BEDROCK)   ${NC}"
echo -e "${MAGENTA}========================================================================${NC}"
echo -e "Timestamp: $(date --rfc-3339=seconds) | Kernel: $(uname -r)\n"

echo -e "${CYAN}--- 1. CORE OS, OSTREE & BOOTCHAIN ---${NC}"
echo -n "Stato Bootc (OCI): "
if command -v bootc >/dev/null 2>&1; then
    bootc status >/dev/null 2>&1 && echo -e "${GREEN}✅ Bootc OK${NC}" || echo -e "${RED}❌ Bootc Fallito${NC}"
else echo -e "${YELLOW}⚠️ bootc non trovato${NC}"; fi

ostree admin config-diff | grep -q . && echo -e "${YELLOW}⚠️ ATTENZIONE: Trovate deviazioni in /etc rispetto all'immagine originaria:${NC}" && ostree admin config-diff || echo -e "${GREEN}✅ Nessuna deviazione in /etc. Immutabilità preservata.${NC}"

[ -f /var/lib/ermete-firstboot-done ] && echo -e "${GREEN}✅ Provisioning ermete-firstboot: Completato${NC}" || echo -e "${RED}❌ Provisioning ermete-firstboot: Mancante o Fallito!${NC}"

echo -e "\n${CYAN}--- 2. SYSTEM SERVICES & eBPF SCHEDULING ---${NC}"
failed_sys=$(systemctl --failed --no-legend | wc -l)
[ "$failed_sys" -eq 0 ] && echo -e "${GREEN}✅ Zero servizi di sistema falliti.${NC}" || echo -e "${RED}❌ Trovati $failed_sys servizi falliti! (esegui systemctl --failed)${NC}"

for srv in greetd.service firewalld.service scx_loader.service fwupd.service; do
    analyze_service "$srv" "system"
done

echo -e "\n${CYAN}--- 3. HARDWARE, DRIVERS & NVIDIA GBM ---${NC}"
if lsmod | grep -q nvidia; then
    echo -e "${GREEN}✅ Modulo NVIDIA caricato.${NC}"
    nvidia-smi --query-gpu=driver_version,temperature.gpu --format=csv,noheader | while read -r val; do echo -e "   Info GPU: $val"; done
else
    echo -e "${RED}❌ Modulo NVIDIA ASSENTE. Il kernel sta usando nouveau o rendering software!${NC}"
fi

cat /sys/module/nvidia_drm/parameters/modeset 2>/dev/null | grep -q 'Y' && echo -e "${GREEN}✅ NVIDIA DRM Modeset abilitato.${NC}" || echo -e "${RED}❌ NVIDIA DRM Modeset disabilitato! Wayland crasherà.${NC}"

echo -e "\n${CYAN}--- 4. ZERO-TRUST SECURITY & ISOLATION ---${NC}"
sestatus | grep -q "Current mode:.*enforcing" && echo -e "${GREEN}✅ SELinux Enforcing.${NC}" || echo -e "${RED}❌ SELinux NON è Enforcing!${NC}"
if command -v ausearch >/dev/null 2>&1; then
    avc_count=$(ausearch -m AVC,USER_AVC -ts recent -i 2>/dev/null | grep -c "denied" || true)
    [ "$avc_count" -gt 0 ] && echo -e "${YELLOW}⚠️ Trovati $avc_count AVC Denials recenti. Controlla audit.log.${NC}" || echo -e "${GREEN}✅ Nessun AVC Denial recente.${NC}"
fi
[ "$(firewall-cmd --get-default-zone 2>/dev/null)" == "drop" ] && echo -e "${GREEN}✅ Firewalld in modalità Paranoica (Drop).${NC}" || echo -e "${YELLOW}⚠️ Firewalld non è in zona 'drop'.${NC}"

echo -e "\n${CYAN}--- 5. WAYLAND, NIRI & SESSIONE UTENTE ---${NC}"
ACTIVE_USER=$(loginctl list-sessions --no-legend | awk '$3 != "root" && $3 != "greeter" {print $3}' | head -n 1)
if [ -n "$ACTIVE_USER" ]; then
    ACTIVE_UID=$(id -u "$ACTIVE_USER")
    echo -e "${GREEN}Utente Wayland attivo: $ACTIVE_USER (UID $ACTIVE_UID)${NC}"
    
    # Check compositor
    analyze_service "niri.service" "user"
    
    # Check XDG Portals and Environment
    echo -n "XDG Desktop Portal: "
    if su -s /bin/bash - "$ACTIVE_USER" -c "XDG_RUNTIME_DIR=/run/user/$ACTIVE_UID systemctl --user is-active xdg-desktop-portal.service" >/dev/null 2>&1; then
        echo -e "${GREEN}✅ Attivo${NC}"
    else
        echo -e "${RED}❌ Inattivo! Analisi Portal:${NC}"
        su -s /bin/bash - "$ACTIVE_USER" -c "XDG_RUNTIME_DIR=/run/user/$ACTIVE_UID journalctl --user -u xdg-desktop-portal.service -n 10 --no-pager" | while read -r line; do echo -e "${RED}   $line${NC}"; done
    fi
    
    # Check User Daemons
    for usrv in ermete-ide-bootstrap.service; do
        analyze_service "$usrv" "user"
    done
    
    # Pipewire Deep Diagnostics
    echo -e "\n>>> Diagnostica Audio (Pipewire):"
    analyze_service "pipewire.service" "user"
    analyze_service "wireplumber.service" "user"
    su -s /bin/bash - "$ACTIVE_USER" -c "XDG_RUNTIME_DIR=/run/user/$ACTIVE_UID wpctl status 2>/dev/null | grep -iE 'audio|server|pulse'" | while read -r line; do echo -e "   $line"; done
else
    echo -e "${YELLOW}⚠️ Nessuna sessione utente attiva trovata. Salto test Wayland.${NC}"
fi

echo -e "\n${CYAN}--- 6. PACKAGE MANAGERS & SANDBOXING (NIX & FLATPAK) ---${NC}"
if systemctl is-active --quiet nix-daemon.socket; then
    echo -e "${GREEN}✅ Nix-daemon socket in ascolto.${NC}"
    [ -d /nix/var/nix/profiles ] && echo -e "${GREEN}✅ Stato Nix (/var) montato e persistente.${NC}" || echo -e "${RED}❌ Amnesia Nix: Stato /var non ripristinato!${NC}"
else
    echo -e "${RED}❌ Nix-daemon socket fallito!${NC}"
fi

echo -e ">>> Verifica Overrides Flatpak (Aesthetics & Security):"
flatpak override --show | grep -q "GTK_THEME=adw-gtk3-dark" && echo -e "${GREEN}✅ Flatpak GTK_THEME Override applicato.${NC}" || echo -e "${RED}❌ Flatpak Override mancanti!${NC}"
flatpak list --columns=application | grep -E "firefox|obs|easyeffects" | while read -r app; do echo -e "${GREEN}✅ $app installato e confinato.${NC}"; done

echo -e "\n${CYAN}--- 7. UI/UX AESTHETICS & CLI TOOLS ---${NC}"
for tool in foot swaylock fuzzel wl-copy playerctl brightnessctl wlr-randr starship btop wlogout pavucontrol thunar; do
    command -v $tool >/dev/null 2>&1 && echo -e "${GREEN}✅ $tool: Presente${NC}" || echo -e "${RED}❌ $tool: MANCANTE O ROTTO!${NC}"
done

echo -e ">>> Integrità Asset Visivi:"
[ -d /usr/share/themes/adw-gtk3-dark ] && echo -e "${GREEN}✅ Tema GTK (adw-gtk3-dark)${NC}" || echo -e "${RED}❌ Tema GTK Mancante${NC}"
[ -d /usr/share/icons/Papirus-Dark ] && echo -e "${GREEN}✅ Icone (Papirus-Dark)${NC}" || echo -e "${RED}❌ Icone Mancanti${NC}"
[ -d /usr/share/icons/Bibata-Modern-Classic ] && echo -e "${GREEN}✅ Cursori (Bibata)${NC}" || echo -e "${RED}❌ Cursori Mancanti${NC}"
ls /usr/share/fonts/jetbrains-mono* >/dev/null 2>&1 && echo -e "${GREEN}✅ Font: JetBrains Mono${NC}" || echo -e "${RED}❌ Font: JetBrains Mono Mancante${NC}"
ls /usr/share/fonts/rsms-inter* >/dev/null 2>&1 && echo -e "${GREEN}✅ Font: Inter${NC}" || echo -e "${RED}❌ Font: Inter Mancante${NC}"

echo -e "\n${MAGENTA}========================================================================${NC}"
echo -e "${GREEN}✅ Ecoscandaglio Estremo Concluso. Log salvato in: $LOG_FILE${NC}"
echo -e "${MAGENTA}========================================================================${NC}"
