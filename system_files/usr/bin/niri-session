#!/bin/bash
# Wrapper di sessione: innesca l'albero DBus, XDG-Desktop-Portal e Pipewire
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=niri
export XDG_SESSION_DESKTOP=niri

# Fix per GTK4 su NVIDIA (Wayland): Forza OpenGL invece di Vulkan per evitare
# i crash (vkAcquireNextImageKHR VK_ERROR_OUT_OF_DATE_KHR)
export GSK_RENDERER=gl

# Importa le variabili nel manager systemd --user e nell'ambiente DBus
systemctl --user import-environment XDG_SESSION_TYPE XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP GSK_RENDERER
dbus-update-activation-environment --systemd XDG_SESSION_TYPE XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP GSK_RENDERER

# Delegazione a systemd dell'esecuzione del compositor (Niri 0.1.8+ nativo)
# Questo fa in modo che `niri.service` venga lanciato correttamente
# agganciando in automatico `niri-session.target` e le dipendenze DBus/graphical.
exec systemctl --user start --wait niri.service
