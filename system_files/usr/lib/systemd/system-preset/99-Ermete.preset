enable podman.socket
disable systemd-oomd.service
enable bootc-fetch-apply-updates.timer
enable firewalld.service
enable btrfs-maintenance.timer
enable fstrim.timer
enable ermete-home-snapshot.service
enable ananicy-cpp.service
enable fwupd.service
enable scx_loader.service
enable Ermete-firstboot.service
enable Ermete-flatpak-update.timer
enable nix-daemon.socket
enable greetd.service
enable bluetooth.service
enable nix-store.mount
enable nix-var.mount


# Disable libvirt/virtualization background daemons for baremetal (Zero-Boot-Delay)
disable libvirtd.service
disable virtqemud.service
disable virtlxcd.service
disable virtvboxd.service
disable virtxend.service
disable virtnodedevd.service
disable virtstoraged.service
disable virtnetworkd.service
disable virtproxyd.service
disable virtsecretd.service
disable virtnwfilterd.service
disable virtinterfaced.service
disable libvirt-guests.service
