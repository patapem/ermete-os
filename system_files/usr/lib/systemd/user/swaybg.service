[Unit]
Description=Swaybg (Wallpaper Daemon)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/bin/sh -c "if [ -s /usr/share/backgrounds/ermete/default.jpg ]; then exec swaybg -m fill -i /usr/share/backgrounds/ermete/default.jpg; else exec swaybg -c '#24273A'; fi"
Restart=on-failure
RestartSec=2
Slice=app-graphical.slice

[Install]
WantedBy=graphical-session.target
