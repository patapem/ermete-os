[Unit]
Description=EasyEffects Audio Processing
PartOf=graphical-session.target
Requires=pipewire.service wireplumber.service
After=graphical-session.target pipewire.service wireplumber.service

[Service]
ExecStart=/usr/bin/flatpak run --command=easyeffects com.github.wwmm.easyeffects --gapplication-service
Restart=on-failure
RestartSec=2
Slice=session.slice

[Install]
WantedBy=graphical-session.target
