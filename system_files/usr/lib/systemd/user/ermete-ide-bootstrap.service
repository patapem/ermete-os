[Unit]
Description=Ermete OS: Bootstrap Nix IDE Stack (gcc, make, lazygit)
After=niri.service
ConditionPathExists=!%h/.local/state/ermete-ide-bootstrapped


[Service]
Type=oneshot
ExecStart=/usr/libexec/ermete-ide-bootstrap.sh
RemainAfterExit=yes
Restart=on-failure
RestartSec=60

[Install]
WantedBy=default.target
