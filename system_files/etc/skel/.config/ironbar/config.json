{
  "position": "top",
  "height": 40,
  "margin": {
    "top": 8,
    "left": 16,
    "right": 16,
    "bottom": 0
  },
  "start": [
    {
      "type": "custom",
      "class": "os-logo",
      "bar": [
        {
          "type": "label",
          "label": "🦅"
        }
      ]
    },
    {
      "type": "workspaces",
      "name_map": {
        "1": "I",
        "2": "II",
        "3": "III",
        "4": "IV",
        "5": "V"
      }
    }
  ],
  "center": [
    {
      "type": "clock",
      "format": "  %a %d %b     %H:%M"
    }
  ],
  "end": [
    {
      "type": "tray",
      "icon_size": 18
    },
    {
      "type": "sys_info",
      "format": [" {cpu_percent}%", " {memory_percent}%"]
    }
  ]
}
