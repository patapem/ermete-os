{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,
    "spacing": 5,

    "modules-left": ["custom/launcher", "niri/workspaces", "niri/window"],
    "modules-center": ["mpris", "clock"],
    "modules-right": ["tray", "custom/notification", "cpu", "memory", "idle_inhibitor", "wireplumber", "network", "battery", "custom/power"],

    "custom/launcher": {
        "format": "ЁЯРжтАНтмЫ",
        "on-click": "fuzzel",
        "tooltip": false
    },

    "custom/left": {
        "format": "яБУ",
        "on-click": "niri msg action focus-column-left",
        "tooltip": false
    },

    "custom/right": {
        "format": "яБФ",
        "on-click": "niri msg action focus-column-right",
        "tooltip": false
    },

    "custom/close": {
        "format": "яАН",
        "on-click": "niri msg action close-window",
        "tooltip": false
    },

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "яЖТ",
            "default": "яДС",
            "urgent": "яБк"
        },
        "on-scroll-up": "niri msg action focus-workspace-up",
        "on-scroll-down": "niri msg action focus-workspace-down"
    },

    "niri/window": {
        "format": "{}",
        "max-length": 50,
        "rewrite": {
            "(.*) - Mozilla Firefox": "яЙй $1",
            "(.*) - Visual Studio Code": "ґ░иЮ $1"
        },
        "on-scroll-up": "niri msg action focus-column-left",
        "on-scroll-down": "niri msg action focus-column-right",
        "on-click-middle": "niri msg action close-window"
    },

    "clock": {
        "format": "яАЧ {:%H:%M}",
        "format-alt": "яБ│ {:%A, %B %d, %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "яЪй Muted",
        "format-icons": ["яАж", "яАз", "яАи"],
        "on-click": "pavucontrol"
    },

    "mpris": {
        "format": "ЁЯО╡ {artist} - {title}",
        "format-paused": "тП╕ {artist} - {title}",
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next"
    },

    "cpu": {
        "format": "яЛЫ {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        "format": "яФ╕ {percentage}%",
        "interval": 2
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "тШХ",
            "deactivated": "ЁЯТд"
        },
        "tooltip": true
    },

    "custom/notification": {
        "tooltip": false,
        "format": "яГ│",
        "on-click": "makoctl dismiss -a",
        "on-click-right": "makoctl restore"
    },

    "network": {
        "format-wifi": "яЗл",
        "format-ethernet": "яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} ({ipaddr})",
        "format-linked": "яЮЦ",
        "format-disconnected": "тЪа"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },

    "custom/power": {
        "format": "яАС",
        "on-click": "wlogout",
        "tooltip": false
    }
}
