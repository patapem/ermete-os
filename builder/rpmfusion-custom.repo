[rpmfusion-free]
name=RPM Fusion for Fedora 43 - Free
metalink=https://mirrors.rpmfusion.org/metalink?repo=free-fedora-$releasever&arch=$basearch
enabled=1
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-41
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora
gpgkey=https://mirrors.rpmfusion.org/RPM-GPG-KEY-rpmfusion-free-fedora-41
skip_if_unavailable=1

[rpmfusion-nonfree]
name=RPM Fusion for Fedora 43 - Nonfree
metalink=https://mirrors.rpmfusion.org/metalink?repo=nonfree-fedora-$releasever&arch=$basearch
enabled=1
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-nonfree-fedora-41
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-nonfree-fedora
gpgkey=https://mirrors.rpmfusion.org/RPM-GPG-KEY-rpmfusion-nonfree-fedora-41
skip_if_unavailable=1

[rpmfusion-free-source]
name=RPM Fusion for Fedora 43 - Free - Source
metalink=https://mirrors.rpmfusion.org/metalink?repo=free-fedora-source-$releasever&arch=$basearch
enabled=1
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-41
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora
gpgkey=https://mirrors.rpmfusion.org/RPM-GPG-KEY-rpmfusion-free-fedora-41
skip_if_unavailable=1

[rpmfusion-nonfree-source]
name=RPM Fusion for Fedora 43 - Nonfree - Source
metalink=https://mirrors.rpmfusion.org/metalink?repo=nonfree-fedora-source-$releasever&arch=$basearch
enabled=1
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-nonfree-fedora-41
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-nonfree-fedora
gpgkey=https://mirrors.rpmfusion.org/RPM-GPG-KEY-rpmfusion-nonfree-fedora-41
skip_if_unavailable=1
