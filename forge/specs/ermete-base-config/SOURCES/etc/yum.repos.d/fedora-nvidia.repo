[fedora-nvidia]
name=negativo17 - Nvidia
baseurl=https://negativo17.org/repos/nvidia/fedora-$releasever/$basearch/
enabled=1
exclude=*nvidia* *nvrm* *cuda*
skip_if_unavailable=1
gpgcheck=1
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-negativo17
enabled_metadata=1
metadata_expire=6h
type=rpm-md
repo_gpgcheck=0
